# ── Supabase (required) ─────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── LLM providers (at least one required for briefings/summaries) ──────────
# Gemini is the default; Groq is used as secondary for larger prompts
GEMINI_API_KEY=
GROQ_API_KEY=

# Hard daily caps (protect free tier quotas)
MAX_DAILY_LLM_CALLS=200
MAX_DAILY_LLM_CALLS_BRIEFING=20
MAX_DAILY_LLM_CALLS_SIGNALS=150
MAX_DAILY_LLM_CALLS_CONTRADICTION=30

# Per-user beta limits
USER_DAILY_CHAT_LIMIT=10
USER_DAILY_PRIORITY_ALERT_LIMIT=5
USER_DAILY_BRIEFING_NOTIFICATION_LIMIT=1
USER_DAILY_BRIEFING_CALL_LIMIT=2

# ── Alerts & delivery (optional) ───────────────────────────────────────────
# Optional Telegram fallback alert channel (operator channel, not per-user)
TELEGRAM_BOT_TOKEN=
TELEGRAM_OPERATOR_CHAT_ID=

# Transactional email provider (used for outbound user email if/when enabled).
# Supply ONE of these; Resend is the historical default, Brevo triples the
# free daily ceiling (see docs/production-plan.md).
RESEND_API_KEY=
BREVO_API_KEY=
BRIEFING_FROM_EMAIL=

# ── Operator self-monitoring (automatic "email me on any issue") ───────────
# When a background job fails, partially fails with errors, or the worker
# crashes, the worker emails this address via whichever provider key above is
# set (Resend/Brevo), with Telegram as an extra channel. The watchdog cron
# (.github/workflows/watchdog.yml) also uses this to catch a silently stalled
# pipeline. Alerts are de-duplicated per throttle window (see migration 030).
OPERATOR_ALERT_EMAIL=calebphillips.ai@gmail.com
ALERT_FROM_EMAIL=alerts@crosscheck.news
# Minutes to collapse identical alerts into one email (default 60).
OPERATOR_ALERT_THROTTLE_MINUTES=60

# ── Support / donations (optional, shown on /pricing + footer) ─────────────
# Public "support the project" links. Left blank, the buttons are hidden and
# the page still renders its "free forever" message. No billing backend is
# wired — these are just outbound links (GitHub Sponsors / Stripe Payment
# Link / Open Collective, etc.).
NEXT_PUBLIC_SPONSOR_URL=
NEXT_PUBLIC_DONATE_URL=

# ── App config ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Public trust/contact addresses used in footer, policy pages, and security.txt
SUPPORT_EMAIL=hello@crosscheck.news
PRIVACY_EMAIL=privacy@crosscheck.news
SECURITY_EMAIL=security@crosscheck.news
LEGAL_EMAIL=legal@crosscheck.news
# Admin users who can access /ops pages (comma-separated)
ADMIN_EMAILS=
# Signed secret for worker -> web callback endpoints
WORKER_SHARED_SECRET=

# Rate limiting (Upstash Redis free tier; optional — falls back to in-memory)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Live corroboration fan-out (optional but strongly recommended) ─────────
# The /verify flow and the "Develop this story" button parallel-query these
# systems. Each one is optional — when a key is absent, that system reports
# `unavailable` in the coverage strip instead of producing evidence.

# Firecrawl — broad web search (free tier: 500 pages/mo).
# https://www.firecrawl.dev/
FIRECRAWL_API_KEY=

# Brave Search API — fallback / secondary web index (free tier: 2k queries/mo).
# https://brave.com/search/api/
BRAVE_SEARCH_API_KEY=

# Bluesky AppView — public search started requiring auth in 2025. Supply an
# app password (NOT your main password) so we can hit the search endpoint
# without 403ing. https://bsky.app/settings/app-passwords
BLUESKY_IDENTIFIER=
BLUESKY_APP_PASSWORD=

# Reddit — anonymous datacenter traffic gets 403'd. Create a free "script" app
# at https://www.reddit.com/prefs/apps (no user login required). Reddit gives
# you a client_id (under the app name) and a client_secret. Both required to
# enable Reddit corroboration on hosted deploys like Vercel.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# ── Specialized claim evidence (optional, all free/free-tier) ───────────────
# The case-file verifier routes atomic claims to these systems by topic. When
# a key is absent, the system reports `unavailable` instead of failing.
GOOGLE_FACTCHECK_API_KEY=
OPENALEX_API_KEY=
NCBI_API_KEY=
COURTLISTENER_API_TOKEN=
SEC_USER_AGENT="Crosscheck hello@crosscheck.news"
CROSSREF_MAILTO=hello@crosscheck.news

# ── Worker → web HTTP (required for the `develop` cron) ────────────────────
# The develop cron job (apps/worker/src/jobs/develop.ts) calls the deployed
# web app's /api/signal/:id/develop endpoint so the live-source credentials
# stay on the web side only. Set this to your production app URL and configure
# the same WORKER_SHARED_SECRET in both the web app and worker environments.
WEB_APP_URL=
